// .zed/tasks.json
[
  {
    "label": "Compile and Run C",
    "command": "sh",
    "args": [
      "-c",
      "gcc '${file}' -o '${file_base_name}' && ./${file_base_name}",
    ],
    "cwd": "${file_directory}",
    "reveal": "always",
    "platforms": ["linux", "darwin"],
  },
  {
    "label": "Compile and Run C (Windows)",
    "command": "cmd",
    "args": [
      "/C",
      "gcc \"${file}\" -o \"${file_base_name}.exe\" && \"${file_base_name}.exe\"",
    ],
    "cwd": "${file_directory}",
    "reveal": "always",
    "platforms": ["win32"],
  },
]
